OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false

# Optional: Local knowledge base and memory settings
RAG_ENABLED=false
LOCAL_KNOWLEDGE_BASE_PATH=
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=.chroma
EMBEDDING_MODEL=openai:text-embedding-3-small
EMBEDDING_PROVIDER=openai
EMBEDDING_ENCODING_FORMAT=float
EMBEDDING_INPUT_TYPE_QUERY=query
EMBEDDING_INPUT_TYPE_DOCUMENT=passage
EMBEDDING_TRUNCATE=NONE
RAG_TOP_K=5

MEMORY_ENABLED=false
MEMORY_WRITE_POLICY=explicit_confirmation
MEMORY_MAX_CANDIDATES_PER_TURN=3
MEMORY_NAMESPACE_PREFIX=memory
USER_ID=